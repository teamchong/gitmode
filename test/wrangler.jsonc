{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "gitmode-test",
  "main": "./worker.ts",
  "compatibility_date": "2025-12-01",
  "compatibility_flags": ["nodejs_compat"],

  "r2_buckets": [
    { "binding": "OBJECTS", "bucket_name": "gitmode-objects-test" }
  ],

  "durable_objects": {
    "bindings": [
      { "name": "REPO_STORE", "class_name": "RepoStore" }
    ]
  },

  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["RepoStore"] }
  ],

  "rules": [
    {
      "type": "CompiledWasm",
      "globs": ["**/*.wasm"],
      "fallthrough": false
    }
  ]
}
