{
  "name": "gitmode",
  "version": "0.1.0",
  "private": true,
  "description": "Git server on Cloudflare Workers — Zig WASM engine with SIMD",
  "type": "module",
  "scripts": {
    "build:wasm": "cd wasm && zig build wasm && mkdir -p ../src/wasm && cp zig-out/bin/gitmode.wasm ../src/wasm/",
    "build": "vite build",
    "dev": "vite dev",
    "preview": "vite preview",
    "deploy": "pnpm run build && wrangler deploy",
    "test:zig": "cd wasm && zig build test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:conformance": "bash test/conformance.sh"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.20",
    "@cloudflare/workers-types": "^4.20250301.0",
    "@vitest/runner": "~3.2.4",
    "@vitest/snapshot": "~3.2.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.71.0"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.26.1",
    "@vitejs/plugin-rsc": "^0.5.21",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-server-dom-webpack": "^19.2.4",
    "vinext": "^0.0.21",
    "vite": "^7.3.1"
  }
}
